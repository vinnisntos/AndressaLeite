# Caddy customizado com o modulo de DNS da Route53 (necessario pro desafio
# DNS-01 do Let's Encrypt, que e o unico jeito de emitir certificado
# wildcard *.suaapp.com — o desafio HTTP-01 padrao nao cobre wildcard).
FROM caddy:2-builder AS builder
RUN xcaddy build --with github.com/caddy-dns/route53

FROM caddy:2
COPY --from=builder /usr/bin/caddy /usr/bin/caddy
