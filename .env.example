# Copie para ".env" (nunca commitar o .env real) e preencha antes de
# `docker compose up -d --build` na instancia EC2.

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
ROOT_DOMAIN=suaapp.com.br
ACME_EMAIL=voce@suaapp.com.br
AWS_REGION=us-east-1

# E-mail transacional (Resend) — esqueci senha, verificacao de e-mail,
# convite de equipe, lembrete automatico de agendamento (readme.txt 9.1).
RESEND_API_KEY=re_...
RESEND_FROM_ADDRESS=MarcAi <noreply@suaapp.com.br>

# Billing (Asaas) — plano unico, trial 14 dias, PIX/Cartao (readme.txt
# 4.9/9.2). Troque ASAAS_BASE_URL/ASAAS_CHECKOUT_BASE_URL pros hosts de
# producao (api.asaas.com / asaas.com) quando sair do sandbox.
ASAAS_API_KEY=$aact_hmlg_...
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3/
ASAAS_CHECKOUT_BASE_URL=https://sandbox.asaas.com/checkoutSession/show
ASAAS_WEBHOOK_TOKEN=um-segredo-qualquer-que-voce-escolher

# Credenciais da AWS para o desafio DNS-01 (emissao do certificado wildcard):
# NAO coloque AWS_ACCESS_KEY_ID/AWS_SECRET_ACCESS_KEY aqui se a instancia EC2
# tiver uma IAM Role anexada com permissao de Route53 (recomendado — ver
# docs/DEPLOY_AWS.md). So preencha estas duas se estiver testando fora da
# EC2 ou sem IAM Role configurada:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
