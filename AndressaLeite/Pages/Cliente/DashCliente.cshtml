@page
@model AndressaLeite.Pages.Cliente.DashClienteModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

@if (Model.CurrentStep == "home")
{
    <div class="mb-4">
        <h4 class="fw-bold mb-1 fs-4">Oi, @Model.ClientName!</h4>
        <p class="text-muted fs-6">É ótimo ter você aqui! O que vamos fazer hoje?</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 small">@Model.ErrorMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="alert alert-success card-custom border-0 p-3 mb-4 small">@Model.SuccessMessage</div>
    }

    <!-- Menu Principal UX Moderno -->
    <div class="d-grid gap-3 mb-5">
        <a asp-page="/Cliente/DashCliente" asp-route-step="pro" class="btn btn-brand py-3 fs-5 rounded-4 shadow-sm text-center">
            📅 Agendar um Horário
        </a>
    </div>

    <!-- Seção de Agendamentos Ativos da Cliente -->
    <h6 class="fw-bold text-secondary text-uppercase tracking-wider small mb-3">Seu próximo atendimento</h6>
    @if (Model.ActiveAppointments != null && Model.ActiveAppointments.Any())
    {
        @foreach (var app in Model.ActiveAppointments)
        {
            <div class="card card-custom p-3 bg-white border-start border-4 border-warning mb-3">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <h6 class="fw-bold mb-1">@app.ServiceName</h6>
                        <p class="text-muted small mb-1">Profissional: <strong>@app.EmployeeName</strong></p>
                        <p class="text-dark small mb-0 fw-medium">⏰ @app.StartTime.ToLocalTime().ToString("dd/MM/yyyy 'às' HH:mm")</p>
                        @if (!string.IsNullOrEmpty(app.BookedForName))
                        {
                            <span class="badge bg-light text-dark border mt-2">Para: @app.BookedForName</span>
                        }
                    </div>
                    <form method="post" asp-page-handler="Cancel" asp-route-id="@app.Id">
                        <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1 rounded-3 small">Cancelar</button>
                    </form>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-4 text-muted bg-white rounded-4 card-custom">
            <p class="small mb-0">Nenhum agendamento ativo no momento.</p>
        </div>
    }

    <div class="text-center mt-3">
        <a asp-page="/Cliente/DashCliente" asp-route-step="historico" class="text-decoration-none text-secondary small">Ver histórico de agendamentos →</a>
    </div>
}

@if (Model.CurrentStep == "historico")
{
    <div class="mb-4">
        <a asp-page="/Cliente/DashCliente" class="text-decoration-none text-secondary small">← Voltar</a>
        <h4 class="fw-bold mt-2 fs-4">Histórico</h4>
        <p class="text-muted fs-6">Seus últimos atendimentos concluídos ou cancelados.</p>
    </div>

    @if (Model.HistoryAppointments.Count == 0)
    {
        <div class="text-center py-4 text-muted bg-white rounded-4 card-custom">
            <p class="small mb-0">Nenhum agendamento concluído ou cancelado ainda.</p>
        </div>
    }
    else
    {
        <div class="list-group gap-2">
            @foreach (var app in Model.HistoryAppointments)
            {
                <div class="card card-custom p-3 bg-white mb-2">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="fw-bold mb-1">@app.ServiceName</h6>
                            <p class="text-muted small mb-1">Profissional: <strong>@app.EmployeeName</strong></p>
                            <p class="text-dark small mb-0">⏰ @app.StartTime.ToLocalTime().ToString("dd/MM/yyyy 'às' HH:mm")</p>
                        </div>
                        <span class="badge @(app.Status == "completed" ? "bg-success" : "bg-secondary")">
                            @(app.Status == "completed" ? "Concluído" : "Cancelado")
                        </span>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex justify-content-between mt-3">
            @if (Model.HistoryPage > 0)
            {
                <a asp-page="/Cliente/DashCliente" asp-route-step="historico" asp-route-HistoryPage="@(Model.HistoryPage - 1)"
                   class="text-decoration-none text-secondary small">← Mais recentes</a>
            }
            else
            {
                <span></span>
            }
            @if (Model.HasMoreHistory)
            {
                <a asp-page="/Cliente/DashCliente" asp-route-step="historico" asp-route-HistoryPage="@(Model.HistoryPage + 1)"
                   class="text-decoration-none text-secondary small">Mais antigos →</a>
            }
        </div>
    }
}

@if (Model.CurrentStep == "pro")
{
    <div class="mb-4">
        <a asp-page="/Cliente/DashCliente" class="text-decoration-none text-secondary small">← Voltar</a>
        <h4 class="fw-bold mt-2 fs-4">Escolha a Profissional</h4>
    </div>
    <div class="list-group gap-2">
        @foreach (var pro in Model.Employees)
        {
            <a asp-page="/Cliente/DashCliente" asp-route-step="service" asp-route-proId="@pro.Id" class="list-group-item list-group-item-action card-custom p-3 bg-white d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="fw-bold mb-0">@pro.FullName</h6>
                    <span class="text-muted small">Designer de Sobrancelhas</span>
                </div>
                <span class="text-muted">➔</span>
            </a>
        }
    </div>
}

@if (Model.CurrentStep == "service")
{
    <div class="mb-4">
        <a asp-page="/Cliente/DashCliente" asp-route-step="pro" class="text-decoration-none text-secondary small">← Voltar</a>
        <h4 class="fw-bold mt-2 fs-4">Escolha o Serviço</h4>
    </div>
    <div class="list-group gap-2">
        @foreach (var srv in Model.Services)
        {
            <a asp-page="/Cliente/DashCliente" asp-route-step="datetime" asp-route-proId="@Model.SelectedProId" asp-route-srvId="@srv.Id" class="list-group-item list-group-item-action card-custom p-3 bg-white">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="fw-bold mb-1">@srv.Name</h6>
                        <p class="text-muted small mb-0">⏱ @srv.DurationMinutes min</p>
                    </div>
                    <span class="fw-bold text-success">R$ @srv.Price</span>
                </div>
            </a>
        }
    </div>
}

@if (Model.CurrentStep == "datetime")
{
    <div class="mb-4">
        <a asp-page="/Cliente/DashCliente" asp-route-step="service" asp-route-proId="@Model.SelectedProId" class="text-decoration-none text-secondary small">← Voltar</a>
        <h4 class="fw-bold mt-2 fs-4">Escolha o Horário</h4>
    </div>
    <form method="post" asp-page-handler="Book">
        <input type="hidden" asp-for="SelectedProId" />
        <input type="hidden" asp-for="SelectedSrvId" />

        <div class="card card-custom p-4 bg-white mb-4">
            <div class="mb-3">
                <label class="form-label small fw-medium">Data e Hora do Atendimento</label>
                <input type="datetime-local" asp-for="SelectedDateTime" class="form-control form-control-lg rounded-3 fs-6" required />
            </div>

            <!-- Mecanismo de Agendamento para Terceiros -->
            <hr class="text-muted my-3" />
            <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" id="flexSwitchCheckDefault" data-bs-toggle="collapse" data-bs-target="#collapseOrdemPessoa">
                <label class="form-check-label small fw-semibold" for="flexSwitchCheckDefault">Agendar para outra pessoa</label>
            </div>

            <div class="collapse" id="collapseOrdemPessoa">
                <div class="mb-3">
                    <label class="form-label small text-secondary">Nome do Dependente</label>
                    <input type="text" asp-for="BookForName" class="form-control rounded-3" placeholder="Nome de quem vai receber o serviço" />
                </div>
                <div class="mb-2">
                    <label class="form-label small text-secondary">Celular do Dependente</label>
                    <input type="tel" asp-for="BookForPhone" class="form-control rounded-3" placeholder="(15) 99999-9999" />
                </div>
            </div>
        </div>

        <div class="d-grid">
            <button type="submit" class="btn btn-brand py-3 rounded-4 fs-6">Confirmar Agendamento ✨</button>
        </div>
    </form>
}