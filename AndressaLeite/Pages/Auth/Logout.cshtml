@page
@model AndressaLeite.Pages.Auth.LogoutModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="my-auto text-center">
    <h2 class="fw-bold fs-3 mb-2">Saindo da sua conta…</h2>
    <p class="text-muted fs-6 mb-4">Você será redirecionada em instantes.</p>
    <form method="post">
        <button type="submit" class="btn btn-brand py-3 px-4 rounded-3 fs-6">Sair agora</button>
    </form>
</div>
