@page
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
    ViewData["Title"] = "Acesso negado";
}

<div class="my-auto text-center">
    <h1 class="fw-bold fs-2 mb-2">Acesso negado</h1>
    <p class="text-muted fs-6 mb-4">
        Sua conta não tem permissão para acessar esta área.
        Se você acha que isso é um engano, entre em contato com a administração.
    </p>
    <a asp-page="/Index" class="btn btn-brand py-3 px-4 rounded-3 fs-6">Voltar para o início</a>
</div>
