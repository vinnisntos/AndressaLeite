@page
@model AndressaLeite.Pages.Auth.LoginModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="my-auto">
    <div class="mb-4 text-center">
        <h2 class="fw-bold mb-1 fs-3">Bem-vinda de volta</h2>
        <p class="text-muted fs-6">Acesse sua conta para gerenciar seus horários</p>
    </div>

    <!-- Mensagens informativas globais -->
    @if (TempData["InfoMessage"] is string info && !string.IsNullOrEmpty(info))
    {
        <div class="alert alert-info card-custom border-0 p-3 mb-4 fs-7" role="alert">@info</div>
    }

    <!-- Mensagens de erros vindas do TempData -->
    @if (TempData["ErrorMessage"] is string err && !string.IsNullOrEmpty(err))
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 fs-7" role="alert">@err</div>
    }

    <!-- 🔴 ADICIONADO: Exibe erros críticos de banco de dados capturados no OnPostAsync -->
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 fs-7" role="alert">
            <strong>Falha técnica no Login:</strong> @Model.ErrorMessage
        </div>
    }

    <!-- Mensagens de validação local (ex: formato de e-mail inválido ou credenciais incorretas) -->
    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 fs-7" role="alert">
            <div asp-validation-summary="All"></div>
        </div>
    }

    <div class="card card-custom p-4 bg-white mb-4">
        <form method="post">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label class="form-label small fw-medium text-secondary">E-mail</label>
                <input type="email" asp-for="Email" class="form-control form-control-lg rounded-3 fs-6"
                       placeholder="seu-email@exemplo.com" autocomplete="email" required />
            </div>
            <div class="mb-4">
                <label class="form-label small fw-medium text-secondary">Sua Senha</label>
                <input type="password" asp-for="Password" class="form-control form-control-lg rounded-3 fs-6"
                       placeholder="******" autocomplete="current-password" required />
            </div>
            <div class="d-grid">
                <button type="submit" class="btn btn-brand py-3 rounded-3 font-medium fs-6">Entrar no Painel</button>
            </div>
        </form>
    </div>

    <div class="text-center">
        <p class="text-muted small">Não possui uma conta? <a asp-page="/Auth/Cadastro" class="text-decoration-none fw-semibold" style="color: #d4a373;">Cadastre-se aqui</a></p>
    </div>
</div>