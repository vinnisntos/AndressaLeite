@page
@model AndressaLeite.Pages.Auth.VerificarEmailModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="my-auto text-center">
    @if (Model.Success)
    {
        <h2 class="fw-bold mb-2 fs-3">E-mail confirmado ✅</h2>
        <p class="text-muted fs-6 mb-4">Seu e-mail foi verificado com sucesso.</p>
    }
    else
    {
        <h2 class="fw-bold mb-2 fs-3">Não foi possível confirmar</h2>
        <p class="text-muted fs-6 mb-4">@Model.ErrorMessage</p>
    }
    <a asp-page="/Index" class="btn btn-brand py-3 px-4 rounded-3 fs-6">Voltar para o início</a>
</div>
