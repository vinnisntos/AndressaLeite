@page
@model AndressaLeite.Pages.SuperAdmin.LoginModel
@{
    Layout = "/Pages/Shared/_Layout.cshtml";
}

<div class="my-auto">
    <div class="mb-4 text-center">
        <h2 class="fw-bold mb-1 fs-3">Painel MarcAi</h2>
        <p class="text-muted fs-6">Acesso restrito da plataforma.</p>
    </div>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 fs-7" role="alert">@Model.ErrorMessage</div>
    }

    @if (!ModelState.IsValid)
    {
        <div class="alert alert-danger card-custom border-0 p-3 mb-4 fs-7" role="alert">
            <div asp-validation-summary="All"></div>
        </div>
    }

    @if (Model.ShowTotpStep)
    {
        <div class="card card-custom p-4 bg-white mb-4">
            <p class="text-muted small mb-3">Digite o código de 6 dígitos do seu app autenticador.</p>
            <form method="post" asp-page-handler="VerifyTotp">
                <input type="hidden" asp-for="PendingToken" />
                <div class="mb-4">
                    <label class="form-label small fw-medium text-secondary">Código</label>
                    <input type="text" asp-for="TotpCode" class="form-control form-control-lg rounded-3 fs-6 text-center"
                           inputmode="numeric" pattern="[0-9]*" maxlength="6" autocomplete="one-time-code" autofocus required />
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-brand py-3 rounded-3 font-medium fs-6">Confirmar</button>
                </div>
            </form>
        </div>
    }
    else
    {
        <div class="card card-custom p-4 bg-white mb-4">
            <form method="post">
                <div class="mb-3">
                    <label class="form-label small fw-medium text-secondary">E-mail</label>
                    <input type="email" asp-for="Email" class="form-control form-control-lg rounded-3 fs-6"
                           autocomplete="username" required />
                </div>
                <div class="mb-4">
                    <label class="form-label small fw-medium text-secondary">Senha</label>
                    <input type="password" asp-for="Password" class="form-control form-control-lg rounded-3 fs-6"
                           autocomplete="current-password" required />
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-brand py-3 rounded-3 font-medium fs-6">Entrar</button>
                </div>
            </form>
        </div>
    }
</div>
