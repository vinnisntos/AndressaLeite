<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, shrink-to-fit=no" />
    <title>@(CurrentTenant.IsResolved ? CurrentTenant.Name : "MarcAi")</title>
    <!-- Bootstrap 5 CSS via CDN para performance -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Google Fonts Inter para UI moderna -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
            body {
                font-family: 'Inter', sans-serif;
                background-color: #f8f9fa;
                color: #212529;
                -webkit-font-smoothing: antialiased;
            }
            .btn-brand {
                background-color: #d4a373;
                color: #ffffff;
                border: none;
                font-weight: 500;
                transition: all 0.2s ease;
            }
            .btn-brand:hover, .btn-brand:focus {
                background-color: #bfa07a;
                color: #ffffff;
                box-shadow: 0 4px 12px rgba(212, 163, 115, 0.2);
            }
            .card-custom {
                border: none;
                border-radius: 16px;
                box-shadow: 0 4px 18px rgba(0, 0, 0, 0.03);
            }
            .form-control:focus {
                border-color: #d4a373;
                box-shadow: 0 0 0 0.25rem rgba(212, 163, 115, 0.15);
            }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">

    <!-- Navbar com navegação role-based -->
    <partial name="_Navbar" />

    <main role="main" class="flex-grow-1 container d-flex flex-column px-4 py-4" style="max-width: 500px;">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>