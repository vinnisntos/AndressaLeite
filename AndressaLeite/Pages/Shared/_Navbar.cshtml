@using System.Security.Claims

@using AndressaLeite.Services
@{
    // Partial view para navbar role-based
    // Acesso aos claims do usuário autenticado
    var userRole = User?.FindFirstValue(ClaimTypes.Role) ?? string.Empty;
    var isAuthenticated = User?.Identity?.IsAuthenticated ?? false;
    // Soft verification (readme.txt 4.2) — não bloqueia nada, só mostra o
    // aviso. Superadmin não tem e-mail verificável nesse sentido (conta
    // cross-tenant, sem a claim), então não entra nessa checagem.
    var showEmailVerificationBanner = isAuthenticated
        && !userRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase)
        && User!.FindFirstValue(AuthorizationService.EmailVerifiedClaimType) == "False";
}

<nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom sticky-top py-3">
    <div class="container-fluid px-4">
        <!-- Brand/Logo: nome do salão do tenant atual, ou o nome da
             plataforma quando não há tenant resolvido (domínio raiz). -->
        <a class="navbar-brand fw-bold text-uppercase tracking-tight fs-6" asp-page="/Index">
            @(CurrentTenant.IsResolved ? CurrentTenant.Name : "MarcAi")
        </a>

        <!-- Toggle Button (Mobile) -->
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" 
                aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
            <span class="navbar-toggler-icon"></span>
        </button>

        <!-- Nav Items -->
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto d-flex gap-3">
                <!-- Home (sempre disponível) -->
                <li class="nav-item">
                    <a class="nav-link" asp-page="/Index">Home</a>
                </li>

                @if (isAuthenticated && userRole.Equals("superadmin", StringComparison.OrdinalIgnoreCase))
                {
                    <!-- Superadmin da plataforma: cross-tenant, não tem
                         Meu Perfil nem dashboard de salão nenhum. -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/SuperAdmin/Dashboard">
                            <i class="bi bi-shield-lock"></i> Painel MarcAi
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/SuperAdmin/Security">Segurança</a>
                    </li>
                    <li class="nav-item">
                        <form method="post" asp-page="/Auth/Logout">
                            <button type="submit" class="nav-link text-danger border-0 bg-transparent p-0">Sair</button>
                        </form>
                    </li>
                }
                else if (isAuthenticated)
                {
                    <!-- Meu Perfil (apenas autenticado) -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Perfil">Meu Perfil</a>
                    </li>

                    <!-- Painel de Administrador (apenas admin) -->
                    @if (userRole.Equals("admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Admin/DashAdmin">
                                <i class="bi bi-speedometer2"></i> Painel Admin
                            </a>
                        </li>
                    }

                    <!-- Dashboard da Role (client/employee/admin) -->
                    @if (userRole.Equals("client", StringComparison.OrdinalIgnoreCase))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Cliente/DashCliente">Meus Agendamentos</a>
                        </li>
                    }
                    else if (userRole.Equals("employee", StringComparison.OrdinalIgnoreCase) ||
                             userRole.Equals("admin", StringComparison.OrdinalIgnoreCase))
                    {
                        <!-- Admin é "profissional premium" (Fase 6 do roadmap):
                             tem agenda própria além do Painel Admin. -->
                        <li class="nav-item">
                            <a class="nav-link" asp-page="/Profissional/DashProfissional">Minha Agenda</a>
                        </li>
                    }

                    <!-- Logout (apenas autenticado) -->
                    <li class="nav-item">
                        <form method="post" asp-page="/Auth/Logout">
                            <button type="submit" class="nav-link text-danger border-0 bg-transparent p-0">Sair</button>
                        </form>
                    </li>
                }
                else if (CurrentTenant.IsResolved)
                {
                    <!-- Login/Cadastro (não autenticado, dentro do subdomínio de um salão) -->
                    <li class="nav-item">
                        <a class="nav-link" asp-page="/Auth/Login">Entrar</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link btn btn-brand px-3 text-white rounded-pill" asp-page="/Auth/Cadastro">
                            Cadastrar
                        </a>
                    </li>
                }
                else
                {
                    <!-- Contexto plataforma (sem tenant resolvido): não há
                         Login/Cadastro de salão nenhum aqui, só o onboarding. -->
                    <li class="nav-item">
                        <a class="nav-link btn btn-brand px-3 text-white rounded-pill" asp-page="/Onboarding/CriarSalao">
                            Criar meu salão
                        </a>
                    </li>
                }
            </ul>
        </div>
    </div>
</nav>

@if (showEmailVerificationBanner)
{
    <div class="d-flex align-items-center justify-content-center gap-2 py-2 px-3 small" style="background-color: #fbf0df; color: #96601f;">
        <span>Confirme seu e-mail pra garantir o acesso à sua conta.</span>
        <form method="post" asp-page="/Perfil" asp-page-handler="ResendVerification" class="d-inline">
            <button type="submit" class="btn btn-link btn-sm p-0 fw-semibold text-decoration-underline" style="color: #96601f;">Reenviar e-mail</button>
        </form>
    </div>
}

<style>
    .navbar {
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
    }

    .navbar-nav .nav-link {
        font-weight: 500;
        color: #212529 !important;
        transition: color 0.2s ease;
    }

    .navbar-nav .nav-link:hover {
        color: #d4a373 !important;
    }

    .navbar-brand {
        letter-spacing: 0.05em;
        color: #212529 !important;
    }

    .btn-brand {
        background-color: #d4a373;
        color: #ffffff;
        border: none;
        font-weight: 500;
        transition: all 0.2s ease;
    }

    .btn-brand:hover, .btn-brand:focus {
        background-color: #bfa07a;
        color: #ffffff;
        box-shadow: 0 4px 12px rgba(212, 163, 115, 0.2);
    }
</style>
